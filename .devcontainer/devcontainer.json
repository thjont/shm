{
  "name": "shm",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
  "features": {
    "ghcr.io/devcontainers/features/node:": {
      "version": "lts"
    },
    "ghcr.io/devcontainers/features/hugo:1": {
      "extended": true,
      "version": "0.163.1"
    },
    "ghcr.io/devcontainers/features/python:1": {
      "version": "latest"
    }
  },
  "onCreateCommand": "npm install && pip install -r requirements.txt && pip install -r qr-pdf/requirements.txt",
  "postStartCommand": "hugo server --bind 0.0.0.0 --source shiny-hoppy-meeple",
  "forwardPorts": [1313],
  "portsAttributes": {
    "1313": {
      "label": "Hugo server",
      "onAutoForward": "openPreview"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "cloudflare.cloudflare-workers-bindings-extension",
        "budparr.language-hugo-vscode",
        "DavidAnson.vscode-markdownlint"
      ],
      "settings": {
        "editor.formatOnSave": true
      }
    }
  },
  "remoteUser": "vscode"
}
