{{- $mainLibIds := dict }}
{{- range (index hugo.Data "bgg-cache" "collections" "main-library").items }}
  {{- $mainLibIds = merge $mainLibIds (dict (string .id) true) }}
{{- end }}

{{- range $key, $game := index hugo.Data "bgg-cache" "games" }}
  {{- $override := index hugo.Data "definitions" "games-bgg-override" $key }}
  {{- if $override }}
    {{- $game = merge $game $override }}
  {{- end }}
  {{- $params := dict "game" $game }}
  {{- if index $mainLibIds (string $game.id) }}
    {{- $params = merge $params (dict "categories" $game.categories "mechanics" $game.mechanics) }}
    {{- $complexity := partial "shm/complexity-bucket.html" $game.rating_average_weight }}
    {{- if $complexity }}
      {{- $params = merge $params (dict "complexity" (slice $complexity)) }}
    {{- end }}
  {{- end }}
  {{- $.AddPage (dict
    "path"   (anchorize $game.name)
    "title"  $game.name
    "params" $params
  ) }}
{{- end }}
