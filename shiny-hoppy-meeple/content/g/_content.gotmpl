{{- range $key, $game := .Site.Data.games }}
  {{- $override := index $.Site.Data.games_overrides $key }}
  {{- if $override }}
    {{- $game = merge $game $override }}
  {{- end }}
  {{- $.AddPage (dict
    "path"   (anchorize $game.name)
    "title"  $game.name
    "params" (dict "game" $game)
  ) }}
{{- end }}
